# Copy this file to .env (it's gitignored) and tweak as needed:
#   cp .env.example .env

# Host-side ports. Override if these clash with something already running.
POSTGRES_PORT=5432
API_PORT=8000
FRONTEND_PORT=3000

# Fernet key for encrypting stored GitHub tokens. 32-byte URL-safe base64.
# The value below is safe for LOCAL DEVELOPMENT ONLY. Generate your own for
# anything else:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=1_feWs3x36asN96yT645MXa-sjBBK8sC44tiQlOYbz0=

# ---- Authentication -------------------------------------------------------
# Pick a provider: "github" (quick start, OAuth App) or "oidc" (enterprise
# IdPs like Keycloak, Auth0, Authentik). The backend exposes the active
# provider's settings via GET /v1/config, which the frontend fetches at
# startup. /v1/config returns 503 until the required vars are set, and the
# frontend shows a config-error page.
AUTH_PROVIDER=

# Where the backend redirects the browser after sign-in completes. For local
# dev with docker-compose, leave the default.
FRONTEND_BASE_URL=http://localhost:3000

# -- GitHub mode (AUTH_PROVIDER=github) --
# Register an OAuth App at https://github.com/settings/developers with
# Authorization callback URL = <frontend-origin>/auth/github/callback
# e.g. for local dev: http://localhost:3000/auth/github/callback
# (the frontend proxies /auth/* to the backend, which keeps the CSRF state
# cookie same-origin — don't use the backend port here)
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Secret used to sign session JWTs. 32+ bytes, any random string. Generate one:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
AUTH_JWT_SECRET=

# -- OIDC mode (AUTH_PROVIDER=oidc) --
OIDC_ISSUER=
OIDC_CLIENT_ID=
# OIDC_SCOPE=openid email profile   # defaults to "openid email profile"

# ---- GitHub Enterprise Server (optional) ----------------------------------
# Only needed for self-hosted GHES. Point at your instance's REST API root.
# Leave unset for GitHub.com and GitHub Enterprise Cloud.
# GITHUB_URL=https://ghe.example.com/api/v3
